---
interface Tile {
  level: number;
  change_abs: number | null;
  change_pct: number | null;
  flag_color: 'red' | 'yellow' | 'green';
  flag_emoji: string;
  flag_message: string;
}

interface Props {
  nq: Tile | null;
  cl: Tile | null;
}

const { nq, cl } = Astro.props;

function fmtLevel(v: number): string {
  return v.toLocaleString(undefined, { maximumFractionDigits: 2 });
}
function fmtAbs(v: number | null): string {
  if (v === null) return '—';
  return `${v >= 0 ? '+' : ''}${v.toFixed(2)}`;
}
function fmtPct(v: number | null): string {
  if (v === null) return '—';
  return `${v >= 0 ? '+' : ''}${v.toFixed(2)}%`;
}

const flagColorVar: Record<string, string> = {
  red: 'var(--status-critical)',
  yellow: 'var(--status-warning)',
  green: 'var(--status-good)',
};
---

<div class="market-context-grid">
  <div class="market-tile">
    <div class="market-tile-head">
      <span class="market-tile-name">Nasdaq futures</span>
      <span class="market-tile-symbol">NQ</span>
    </div>
    {nq ? (
      <>
        <div class="market-tile-level" style={`color:${(nq.change_pct ?? 0) >= 0 ? 'var(--status-good)' : 'var(--status-critical)'}`}>
          {fmtLevel(nq.level)}
        </div>
        <div class="market-tile-change">
          <span>{fmtAbs(nq.change_abs)}</span>
          <span>{fmtPct(nq.change_pct)}</span>
        </div>
        <div class="trading-rule-flag" style={`border-color:${flagColorVar[nq.flag_color]}; color:${flagColorVar[nq.flag_color]}`}>
          <span class="flag-emoji">{nq.flag_emoji}</span>
          <div>
            <div class="flag-label">Your trading rules</div>
            <div class="flag-message">{nq.flag_message}</div>
          </div>
        </div>
      </>
    ) : (
      <div class="market-tile-unavailable">Data unavailable</div>
    )}
  </div>

  <div class="market-tile">
    <div class="market-tile-head">
      <span class="market-tile-name">WTI crude oil futures</span>
      <span class="market-tile-symbol">CL</span>
    </div>
    {cl ? (
      <>
        <div class="market-tile-level" style={`color:${(cl.change_pct ?? 0) >= 0 ? 'var(--status-good)' : 'var(--status-critical)'}`}>
          {fmtLevel(cl.level)}
        </div>
        <div class="market-tile-change">
          <span>{fmtAbs(cl.change_abs)}</span>
          <span>{fmtPct(cl.change_pct)}</span>
        </div>
        <div class="trading-rule-flag" style={`border-color:${flagColorVar[cl.flag_color]}; color:${flagColorVar[cl.flag_color]}`}>
          <span class="flag-emoji">{cl.flag_emoji}</span>
          <div>
            <div class="flag-label">Your trading rules</div>
            <div class="flag-message">{cl.flag_message}</div>
          </div>
        </div>
      </>
    ) : (
      <div class="market-tile-unavailable">Data unavailable</div>
    )}
  </div>
</div>
<p class="market-context-note">
  These flags are her own trading rules, displayed back to her — not a premonition
  recommendation. Nothing here tells you to enter, exit, size, or time a trade.
</p>

<style>
  .market-context-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
    margin: 20px 0 8px;
  }
  .market-tile {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
  }
  .market-tile-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .market-tile-name { font-size: 0.85rem; color: var(--text-secondary); font-weight: 600; }
  .market-tile-symbol { font-size: 0.75rem; color: var(--muted); font-variant-numeric: tabular-nums; letter-spacing: 0.04em; }
  .market-tile-level { font-size: 1.9rem; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1.1; }
  .market-tile-change {
    display: flex; gap: 12px; font-size: 0.95rem; font-weight: 600;
    font-variant-numeric: tabular-nums; color: var(--text-secondary); margin-top: 2px;
  }
  .market-tile-unavailable { color: var(--muted); font-style: italic; padding: 10px 0; }
  .trading-rule-flag {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 14px; padding: 10px 12px;
    border: 1px solid; border-radius: 10px;
    background: color-mix(in srgb, currentColor 8%, transparent);
  }
  .flag-emoji { font-size: 1.1rem; line-height: 1.3; }
  .flag-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
  .flag-message { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); }
  .market-context-note {
    color: var(--muted); font-size: 0.8rem; max-width: 68ch; margin: 0 0 28px;
  }
</style>
