#!/usr/bin/env bash
# bin/premonition-draft — 08:30 ET run. Refreshes all collectors ahead of the
# 09:15 lock. Does not publish anything — see DESIGN.md's schedule table.
set -euo pipefail
cd "$(dirname "$0")/.."
source .venv/bin/activate
# Filter to well-formed KEY=VALUE lines before sourcing — a stray malformed
# line in the secrets file (no =, not a valid identifier) must never be able
# to take down a production run under set -e by being executed as a command.
set -a; source <(grep -E '^[A-Za-z_][A-Za-z0-9_]*=' /etc/premonition/env); set +a

echo "=== $(date) draft run starting ==="
python3 -m seismo.collect_daily --days 90
python3 -m seismo.collect_quotes
python3 -m seismo.collect_fundamentals
python3 -m seismo.collect_earnings
python3 -m seismo.collect_catalysts
python3 -m seismo.collect_macro
python3 -m seismo.collect_macro_news
echo "=== $(date) draft run complete ==="
